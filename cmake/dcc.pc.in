prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: DCC
Description: @PROJECT_DESCRIPTION@
Version: @PROJECT_VERSION@
Requires.private: @DCC_PC_REQUIRES_PRIVATE@
Libs: -L${libdir} -ldcc
Libs.private: @DCC_PC_LIBS_PRIVATE@
Cflags: -I${includedir}
