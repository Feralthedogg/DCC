@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Threads)
find_dependency(OpenSSL)

set(DCC_LLAM_REQUIRED_VERSION "@DCC_LLAM_REQUIRED_VERSION@")
if(NOT DCC_LLAM_REQUIRED_VERSION MATCHES "^([0-9]+)\\.([0-9]+)\\.([0-9]+)$")
    set(dcc_FOUND FALSE)
    set(dcc_NOT_FOUND_MESSAGE "DCC package has an invalid LLAM requirement: ${DCC_LLAM_REQUIRED_VERSION}")
    return()
endif()
set(DCC_LLAM_REQUIRED_VERSION_MAJOR "${CMAKE_MATCH_1}")

function(dcc_link_llam_platform_libraries target)
    if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
        find_library(DCC_URING_LIBRARY uring REQUIRED)
        set_property(TARGET ${target} APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES "${DCC_URING_LIBRARY};m"
        )
    elseif(CMAKE_SYSTEM_NAME STREQUAL "NetBSD")
        set_property(TARGET ${target} APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES rt
        )
    elseif(CMAKE_SYSTEM_NAME STREQUAL "Windows")
        set_property(TARGET ${target} APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES ws2_32 mswsock synchronization advapi32
        )
    endif()
endfunction()

function(dcc_llam_header_define_u32 header define out_var)
    file(
        STRINGS "${header}"
        DCC_LLAM_DEFINE_LINE
        REGEX "^#define[ \t]+${define}[ \t]+[0-9]+U?"
    )
    if(NOT DCC_LLAM_DEFINE_LINE)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "LLAM header ${header} does not define ${define}" PARENT_SCOPE)
        return()
    endif()
    list(GET DCC_LLAM_DEFINE_LINE 0 DCC_LLAM_DEFINE_LINE)
    string(
        REGEX REPLACE "^#define[ \t]+${define}[ \t]+([0-9]+)U?.*$" "\\1"
        DCC_LLAM_DEFINE_VALUE
        "${DCC_LLAM_DEFINE_LINE}"
    )
    set("${out_var}" "${DCC_LLAM_DEFINE_VALUE}" PARENT_SCOPE)
endfunction()

function(dcc_validate_llam_header header)
    if(NOT EXISTS "${header}")
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "LLAM runtime header not found: ${header}" PARENT_SCOPE)
        return()
    endif()

    dcc_llam_header_define_u32("${header}" LLAM_VERSION_MAJOR DCC_LLAM_DETECTED_MAJOR)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
        return()
    endif()
    dcc_llam_header_define_u32("${header}" LLAM_VERSION_MINOR DCC_LLAM_DETECTED_MINOR)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
        return()
    endif()
    dcc_llam_header_define_u32("${header}" LLAM_VERSION_PATCH DCC_LLAM_DETECTED_PATCH)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
        return()
    endif()
    dcc_llam_header_define_u32("${header}" LLAM_ABI_VERSION_MAJOR DCC_LLAM_DETECTED_ABI_MAJOR)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
        return()
    endif()
    dcc_llam_header_define_u32("${header}" LLAM_ABI_VERSION_MINOR DCC_LLAM_DETECTED_ABI_MINOR)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
        return()
    endif()

    set(DCC_LLAM_DETECTED_VERSION
        "${DCC_LLAM_DETECTED_MAJOR}.${DCC_LLAM_DETECTED_MINOR}.${DCC_LLAM_DETECTED_PATCH}"
    )
    if(DCC_LLAM_DETECTED_VERSION VERSION_LESS DCC_LLAM_REQUIRED_VERSION)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE
            "DCC requires LLAM ${DCC_LLAM_REQUIRED_VERSION} or newer; found ${DCC_LLAM_DETECTED_VERSION} at ${header}"
            PARENT_SCOPE
        )
        return()
    endif()
    if(NOT DCC_LLAM_DETECTED_ABI_MAJOR EQUAL DCC_LLAM_REQUIRED_VERSION_MAJOR)
        set(dcc_FOUND FALSE PARENT_SCOPE)
        set(dcc_NOT_FOUND_MESSAGE
            "DCC requires LLAM ABI major ${DCC_LLAM_REQUIRED_VERSION_MAJOR}; found ABI ${DCC_LLAM_DETECTED_ABI_MAJOR}.${DCC_LLAM_DETECTED_ABI_MINOR} at ${header}"
            PARENT_SCOPE
        )
        return()
    endif()
endfunction()

function(dcc_validate_llam_target target)
    get_target_property(DCC_LLAM_INCLUDE_DIRS ${target} INTERFACE_INCLUDE_DIRECTORIES)
    if(NOT DCC_LLAM_INCLUDE_DIRS)
        return()
    endif()
    foreach(DCC_LLAM_INCLUDE_DIR IN LISTS DCC_LLAM_INCLUDE_DIRS)
        string(FIND "${DCC_LLAM_INCLUDE_DIR}" "$<" DCC_LLAM_GENEX_INDEX)
        if(DCC_LLAM_GENEX_INDEX EQUAL 0)
            continue()
        endif()
        if(EXISTS "${DCC_LLAM_INCLUDE_DIR}/llam/runtime.h")
            dcc_validate_llam_header("${DCC_LLAM_INCLUDE_DIR}/llam/runtime.h")
            if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
                set(dcc_FOUND FALSE PARENT_SCOPE)
                set(dcc_NOT_FOUND_MESSAGE "${dcc_NOT_FOUND_MESSAGE}" PARENT_SCOPE)
            endif()
            return()
        endif()
    endforeach()
endfunction()

if(NOT TARGET llam::runtime)
    find_package(llam ${DCC_LLAM_REQUIRED_VERSION} CONFIG QUIET)
endif()

if(TARGET llam::runtime)
    dcc_validate_llam_target(llam::runtime)
    if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
        return()
    endif()
endif()

if(NOT TARGET llam::runtime)
    set(DCC_LLAM_ROOT "" CACHE PATH "Path to an installed or source LLAM tree")
    set(DCC_LLAM_LIBRARY "" CACHE FILEPATH "Path to a prebuilt LLAM runtime library")
    if(DCC_LLAM_ROOT AND DCC_LLAM_LIBRARY AND EXISTS "${DCC_LLAM_ROOT}/include/llam/runtime.h" AND EXISTS "${DCC_LLAM_LIBRARY}")
        dcc_validate_llam_header("${DCC_LLAM_ROOT}/include/llam/runtime.h")
        if(DEFINED dcc_FOUND AND NOT dcc_FOUND)
            return()
        endif()
        add_library(llam_runtime_prebuilt STATIC IMPORTED)
        add_library(llam::runtime ALIAS llam_runtime_prebuilt)
        set_target_properties(llam_runtime_prebuilt PROPERTIES
            IMPORTED_LOCATION "${DCC_LLAM_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${DCC_LLAM_ROOT}/include"
            INTERFACE_LINK_LIBRARIES Threads::Threads
        )
        dcc_link_llam_platform_libraries(llam_runtime_prebuilt)
    endif()
endif()

if(NOT TARGET llam::runtime)
    set(dcc_FOUND FALSE)
    set(dcc_NOT_FOUND_MESSAGE "DCC requires LLAM. Install LLAM's CMake package or configure DCC_LLAM_ROOT and DCC_LLAM_LIBRARY before find_package(dcc).")
    return()
endif()

if(TARGET llam::runtime AND NOT TARGET llam_runtime_prebuilt)
    add_library(llam_runtime_prebuilt INTERFACE IMPORTED)
    set_target_properties(llam_runtime_prebuilt PROPERTIES
        INTERFACE_LINK_LIBRARIES llam::runtime
    )
endif()

if(@DCC_CONFIG_HAVE_OPUS@ AND NOT TARGET dcc_opus)
    find_path(DCC_OPUS_INCLUDE_DIR
        NAMES opus/opus.h
        HINTS ENV OPUS_ROOT /opt/homebrew /usr/local
        PATH_SUFFIXES include
    )
    find_library(DCC_OPUS_LIBRARY
        NAMES opus
        HINTS ENV OPUS_ROOT /opt/homebrew /usr/local
        PATH_SUFFIXES lib
    )
    if(DCC_OPUS_INCLUDE_DIR AND DCC_OPUS_LIBRARY)
        add_library(dcc_opus UNKNOWN IMPORTED)
        set_target_properties(dcc_opus PROPERTIES
            IMPORTED_LOCATION "${DCC_OPUS_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${DCC_OPUS_INCLUDE_DIR}"
        )
    else()
        set(dcc_FOUND FALSE)
        set(dcc_NOT_FOUND_MESSAGE "This DCC package was built with libopus support, but libopus could not be found.")
        return()
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/dcc-targets.cmake")

if(NOT COMMAND dcc_add_hot_reload_module)
    function(dcc_add_hot_reload_module target)
        set(options)
        set(one_value_args OUTPUT_NAME)
        set(multi_value_args SOURCES)
        cmake_parse_arguments(DCC_HOT_RELOAD_MODULE "${options}" "${one_value_args}" "${multi_value_args}" ${ARGN})

        set(sources ${DCC_HOT_RELOAD_MODULE_SOURCES} ${DCC_HOT_RELOAD_MODULE_UNPARSED_ARGUMENTS})
        if(NOT sources)
            message(FATAL_ERROR "dcc_add_hot_reload_module(<target> [SOURCES] <sources...>) requires at least one source")
        endif()

        add_library(${target} MODULE ${sources})
        target_link_libraries(${target} PRIVATE dcc::dcc)
        target_compile_features(${target} PRIVATE c_std_11)
        set_target_properties(${target} PROPERTIES PREFIX "")
        if(DCC_HOT_RELOAD_MODULE_OUTPUT_NAME)
            set_target_properties(${target} PROPERTIES OUTPUT_NAME "${DCC_HOT_RELOAD_MODULE_OUTPUT_NAME}")
        endif()
    endfunction()
endif()

check_required_components(dcc)
