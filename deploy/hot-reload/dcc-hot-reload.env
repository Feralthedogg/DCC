# Discord bot token. DISCORD_TOKEN is also accepted by the host as a fallback.
BOT_TOKEN=replace_with_discord_bot_token

# Watched module file. Replace this file atomically after building a new module.
DCC_BOT_MODULE=/var/lib/dcc/hot_reload/bot.so

# Worker executable. The host defaults to dcc_hot_reload_worker through PATH, but
# production units should pin the installed path.
DCC_HOT_RELOAD_WORKER=/usr/local/bin/dcc_hot_reload_worker

# Slash-command bots only need guilds by default. Add named intents such as
# guild_messages,message_content,voice_states when the module listens to them.
DCC_HOT_RELOAD_INTENTS=guilds

# Optional one-guild development scope. Leave empty for global/all-guild command
# registration.
DCC_HOT_RELOAD_GUILD_ID=

# Loopback parent-process health sidecar. Leave the port empty or remove this
# line to disable GET /hot-reloadz.
DCC_HOT_RELOAD_HEALTH_ADDRESS=127.0.0.1
DCC_HOT_RELOAD_HEALTH_PORT=18080

# Hot reload tuning. Use DCC_HOT_RELOAD_SETTLE_MS=none for explicit immediate
# reloads after file replacement.
DCC_HOT_RELOAD_POLL_MS=250
DCC_HOT_RELOAD_SETTLE_MS=100
DCC_HOT_RELOAD_WORKER_HEALTH_MS=2000
DCC_HOT_RELOAD_WORKER_DRAIN_MS=500
