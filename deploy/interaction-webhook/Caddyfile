{$DCC_INTERACTION_HOST} {
    encode zstd gzip

    handle /healthz {
        reverse_proxy interaction-webhook:8080
    }

    handle /interactions {
        request_body {
            max_size 32KB
        }
        reverse_proxy interaction-webhook:8080 {
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For {remote_host}
            header_up X-Signature-Ed25519 {header.X-Signature-Ed25519}
            header_up X-Signature-Timestamp {header.X-Signature-Timestamp}
        }
    }

    respond 404
}
