# Discord application public key, hex encoded.
DISCORD_PUBLIC_KEY=replace_with_discord_application_public_key

# The DCC process should bind to loopback when nginx terminates TLS.
DCC_INTERACTION_ADDRESS=127.0.0.1
DCC_INTERACTION_PORT=8080
DCC_INTERACTION_PATH=/interactions

# Tune these to match the reverse proxy and expected Discord payload sizes.
DCC_INTERACTION_BACKLOG=128
DCC_INTERACTION_MAX_HEADER=8192
DCC_INTERACTION_MAX_BODY=16384
DCC_INTERACTION_DRAIN_TIMEOUT_MS=10000

# Keep disabled in production. Useful for one-shot local verification only.
DCC_INTERACTION_EXIT_AFTER_ONE=0
